{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "CUDA_VISIBLE_DEVICES": "2",
                "PYTORCH_ALLOC_CONF": "expandable_segments:True"
            },
            "justMyCode": false
        }
    ]
}
